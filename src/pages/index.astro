---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BC // Developer">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-[#0a0a0f]/80 backdrop-blur-md border-b border-cyan-500/10">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="font-mono text-cyan-400 text-lg font-bold">BC<span class="text-purple-400">//</span>dev</a>
      <div class="flex gap-6 text-sm text-slate-400">
        <a href="#about" class="hover:text-cyan-400 transition">About</a>
        <a href="#projects" class="hover:text-cyan-400 transition">Projects</a>
        <a href="#skills" class="hover:text-cyan-400 transition">Skills</a>
        <a href="#blog" class="hover:text-cyan-400 transition">Blog</a>
        <a href="#contact" class="hover:text-cyan-400 transition">Contact</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="min-h-screen flex items-center justify-center pt-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="font-mono text-cyan-400/60 text-sm mb-4">$ whoami</div>
      <h1 class="text-5xl md:text-7xl font-bold mb-6">
        <span class="glow text-cyan-400">Bertha Cornish</span>
      </h1>
      <p class="text-xl md:text-2xl text-slate-400 mb-8 max-w-2xl mx-auto">
        I build <span class="text-cyan-400">secure APIs</span>, 
        <span class="text-purple-400">MCP integrations</span>, and 
        <span class="text-green-400">automation tools</span> that ship fast and don't break.
      </p>
      <div class="font-mono text-sm bg-[#12121a] rounded-lg p-4 inline-block border border-cyan-500/20">
        <span class="text-green-400">$</span> <span class="text-slate-300">npx mcp-shield scan</span>
        <span class="cursor-blink"></span>
      </div>
      <div class="mt-12 flex gap-4 justify-center">
        <a href="https://github.com/bcornish1797" target="_blank" class="px-6 py-3 bg-cyan-500/10 border border-cyan-500/30 rounded-lg text-cyan-400 hover:bg-cyan-500/20 transition font-mono text-sm">
          GitHub →
        </a>
        <a href="#contact" class="px-6 py-3 bg-purple-500/10 border border-purple-500/30 rounded-lg text-purple-400 hover:bg-purple-500/20 transition font-mono text-sm">
          Hire Me →
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-mono text-cyan-400 text-sm mb-2">// about</h2>
      <h3 class="text-3xl font-bold mb-8">What I Do</h3>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-[#12121a] rounded-xl p-6 border border-slate-800 hover:border-cyan-500/30 transition">
          <div class="text-3xl mb-4">🔐</div>
          <h4 class="text-lg font-bold mb-2 text-cyan-400">MCP Security</h4>
          <p class="text-slate-400 text-sm">I build security tooling for Model Context Protocol deployments. Authentication, rate limiting, audit logging — the stuff that keeps AI integrations safe in production.</p>
        </div>
        <div class="bg-[#12121a] rounded-xl p-6 border border-slate-800 hover:border-purple-500/30 transition">
          <div class="text-3xl mb-4">⚡</div>
          <h4 class="text-lg font-bold mb-2 text-purple-400">API Architecture</h4>
          <p class="text-slate-400 text-sm">REST & GraphQL APIs built with TypeScript and Node.js. Clean abstractions, proper error handling, comprehensive tests. Production-grade from day one.</p>
        </div>
        <div class="bg-[#12121a] rounded-xl p-6 border border-slate-800 hover:border-green-500/30 transition">
          <div class="text-3xl mb-4">🤖</div>
          <h4 class="text-lg font-bold mb-2 text-green-400">AI Integration</h4>
          <p class="text-slate-400 text-sm">Claude API, OpenAI, MCP servers — I connect AI to your tools. Browser automation, web scraping, workflow pipelines.</p>
        </div>
        <div class="bg-[#12121a] rounded-xl p-6 border border-slate-800 hover:border-yellow-500/30 transition">
          <div class="text-3xl mb-4">🛠️</div>
          <h4 class="text-lg font-bold mb-2 text-yellow-400">CLI Tools</h4>
          <p class="text-slate-400 text-sm">npm packages and command-line tools that developers actually want to use. Clean interfaces, helpful error messages, zero unnecessary dependencies.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="py-20 bg-[#12121a]/50">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-mono text-cyan-400 text-sm mb-2">// projects</h2>
      <h3 class="text-3xl font-bold mb-8">Featured Work</h3>
      <div class="space-y-6">
        <div class="bg-[#0a0a0f] rounded-xl p-6 border border-slate-800 hover:border-cyan-500/30 transition group">
          <div class="flex justify-between items-start mb-4">
            <h4 class="text-xl font-bold text-white group-hover:text-cyan-400 transition">mcp-shield</h4>
            <a href="https://github.com/bcornish1797/mcp-shield" target="_blank" class="text-slate-500 hover:text-cyan-400 transition text-sm font-mono">GitHub →</a>
          </div>
          <p class="text-slate-400 mb-4">Security CLI for MCP servers. Scans your Claude Desktop/Cursor configs, grades your security posture (A-F), and generates production-ready agentgateway configurations with JWT auth, rate limiting, and audit logging.</p>
          <div class="flex gap-2 flex-wrap">
            <span class="px-2 py-1 bg-cyan-500/10 text-cyan-400 rounded text-xs font-mono">TypeScript</span>
            <span class="px-2 py-1 bg-purple-500/10 text-purple-400 rounded text-xs font-mono">MCP</span>
            <span class="px-2 py-1 bg-green-500/10 text-green-400 rounded text-xs font-mono">agentgateway</span>
            <span class="px-2 py-1 bg-yellow-500/10 text-yellow-400 rounded text-xs font-mono">Security</span>
          </div>
        </div>
        <div class="bg-[#0a0a0f] rounded-xl p-6 border border-slate-800 hover:border-purple-500/30 transition group">
          <div class="flex justify-between items-start mb-4">
            <h4 class="text-xl font-bold text-white group-hover:text-purple-400 transition">starbasedb (Contributor)</h4>
            <a href="https://github.com/outerbase/starbasedb/pull/101" target="_blank" class="text-slate-500 hover:text-purple-400 transition text-sm font-mono">PR #101 →</a>
          </div>
          <p class="text-slate-400 mb-4">Async R2-backed export system for large database dumps on Cloudflare Workers. Handles datasets that exceed memory limits by streaming through R2 storage.</p>
          <div class="flex gap-2 flex-wrap">
            <span class="px-2 py-1 bg-cyan-500/10 text-cyan-400 rounded text-xs font-mono">TypeScript</span>
            <span class="px-2 py-1 bg-orange-500/10 text-orange-400 rounded text-xs font-mono">Cloudflare Workers</span>
            <span class="px-2 py-1 bg-blue-500/10 text-blue-400 rounded text-xs font-mono">R2</span>
            <span class="px-2 py-1 bg-pink-500/10 text-pink-400 rounded text-xs font-mono">Hono</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-mono text-cyan-400 text-sm mb-2">// skills</h2>
      <h3 class="text-3xl font-bold mb-8">Tech Stack</h3>
      <div class="font-mono text-sm bg-[#12121a] rounded-xl p-6 border border-slate-800">
        <div class="mb-4">
          <span class="text-slate-500">languages:</span>
          <span class="text-cyan-400"> TypeScript</span> ·
          <span class="text-cyan-400"> JavaScript</span> ·
          <span class="text-cyan-400"> Python</span>
        </div>
        <div class="mb-4">
          <span class="text-slate-500">backend:</span>
          <span class="text-purple-400"> Node.js</span> ·
          <span class="text-purple-400"> Express</span> ·
          <span class="text-purple-400"> Hono</span> ·
          <span class="text-purple-400"> NestJS</span> ·
          <span class="text-purple-400"> FastAPI</span>
        </div>
        <div class="mb-4">
          <span class="text-slate-500">frontend:</span>
          <span class="text-green-400"> React</span> ·
          <span class="text-green-400"> Next.js</span> ·
          <span class="text-green-400"> Astro</span> ·
          <span class="text-green-400"> Tailwind CSS</span>
        </div>
        <div class="mb-4">
          <span class="text-slate-500">databases:</span>
          <span class="text-yellow-400"> PostgreSQL</span> ·
          <span class="text-yellow-400"> SQLite</span> ·
          <span class="text-yellow-400"> MongoDB</span> ·
          <span class="text-yellow-400"> Supabase</span>
        </div>
        <div class="mb-4">
          <span class="text-slate-500">ai/mcp:</span>
          <span class="text-pink-400"> Claude API</span> ·
          <span class="text-pink-400"> OpenAI</span> ·
          <span class="text-pink-400"> MCP Servers</span> ·
          <span class="text-pink-400"> agentgateway</span>
        </div>
        <div class="mb-4">
          <span class="text-slate-500">infra:</span>
          <span class="text-orange-400"> Docker</span> ·
          <span class="text-orange-400"> GitHub Actions</span> ·
          <span class="text-orange-400"> Cloudflare Workers</span> ·
          <span class="text-orange-400"> Vercel</span>
        </div>
        <div>
          <span class="text-slate-500">tools:</span>
          <span class="text-slate-300"> Git</span> ·
          <span class="text-slate-300"> Playwright</span> ·
          <span class="text-slate-300"> npm</span> ·
          <span class="text-slate-300"> Linux</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section id="blog" class="py-20 bg-[#12121a]/50">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-mono text-cyan-400 text-sm mb-2">// blog</h2>
      <h3 class="text-3xl font-bold mb-8">Writing</h3>
      <div class="space-y-4">
        <a href="https://gist.github.com/bcornish1797/5be04f9a2c03dbb108c4a96b54aa3fe6" target="_blank" class="block bg-[#0a0a0f] rounded-xl p-6 border border-slate-800 hover:border-cyan-500/30 transition group">
          <div class="flex justify-between items-center">
            <div>
              <h4 class="text-lg font-bold text-white group-hover:text-cyan-400 transition">How I Built a Security Scanner for MCP Servers</h4>
              <p class="text-slate-500 text-sm mt-1">MCP security, agentgateway, CLI tooling</p>
            </div>
            <span class="text-slate-600 text-sm font-mono">2026</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-mono text-cyan-400 text-sm mb-2">// contact</h2>
      <h3 class="text-3xl font-bold mb-4">Let's Build Something</h3>
      <p class="text-slate-400 mb-8 max-w-lg mx-auto">Need an API built, an MCP server secured, or a CLI tool that developers will actually love? Let's talk.</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="https://github.com/bcornish1797" target="_blank" class="px-6 py-3 bg-slate-800 rounded-lg text-slate-300 hover:text-white hover:bg-slate-700 transition font-mono text-sm">
          GitHub
        </a>
        <a href="https://www.upwork.com/freelancers/~01a32c32058829ab1b" target="_blank" class="px-6 py-3 bg-green-500/10 border border-green-500/30 rounded-lg text-green-400 hover:bg-green-500/20 transition font-mono text-sm">
          Upwork
        </a>
        <a href="mailto:bcornish1797@live.hccc.edu" class="px-6 py-3 bg-cyan-500/10 border border-cyan-500/30 rounded-lg text-cyan-400 hover:bg-cyan-500/20 transition font-mono text-sm">
          Email
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 border-t border-slate-800">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="font-mono text-slate-600 text-xs">© 2026 BC // Built with Astro + Tailwind</p>
    </div>
  </footer>
</Layout>
